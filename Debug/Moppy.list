static void writeReg16Bit(VL53L0X_Dev *dev, uint8_t reg, uint16_t value) {
    uint8_t buf[2] = { (value >> 8) & 0xFF, value & 0xFF };
    HAL_I2C_Mem_Write(dev->i2c, dev->address, reg, 1, buf, 2, dev->timeout_ms);
}
